<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_em_project_form" model="ir.ui.view">
        <field name="name">em.project.form</field>
        <field name="model">em.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Team" name="team">
                            <field name="employee_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'always'}"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_em_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">em.project</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_project_root" name="Project Management" sequence="20"/>
    <menuitem id="menu_project_list" name="Projects" parent="menu_project_root" action="action_em_project"/>
</odoo>
